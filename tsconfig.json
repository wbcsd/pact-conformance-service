{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useUnknownInCatchVariables": false,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["jest", "node"]
  },
  "exclude": ["__tests__", "**/__tests__/*", "scripts"]
}
